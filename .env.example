# ==============================================================
# SciTools Radar - Variables de Entorno
# ==============================================================
# Copiar a .env y completar con valores reales
# En Railway: configurar en Settings > Variables
# ==============================================================

# --- Flask ---
SECRET_KEY=your-secret-key-here
FLASK_ENV=production
FLASK_APP=wsgi.py

# --- Database (Railway auto-provisioned) ---
DATABASE_URL=postgresql://...

# --- CometAPI - Gateway LLM unificado ---
# Obtener key: https://api.cometapi.com/console/token
COMETAPI_KEY=sk-xxxxx
COMETAPI_BASE_URL=https://api.cometapi.com/v1

# --- Web Search ---
# Obtener key: https://tavily.com
TAVILY_API_KEY=tvly-xxxxx

# --- Admin ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin1234
ADMIN_EMAIL=admin@smartcentrum.edu.pe

# --- Agent Config ---
AGENT_SCHEDULE_HOUR=7
AGENT_SCHEDULE_DAYS=tue,thu
AGENT_MAX_NEW_TOOLS=6
AGENT_MAX_UPDATES=5
AGENT_ENABLED=True

# --- Opcional ---
API_KEY=your-api-key-here
REDIS_URL=
PORT=5000
