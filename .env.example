# Flask
SECRET_KEY=your-secret-key-here
FLASK_ENV=production
FLASK_DEBUG=False
API_KEY=your-api-key-here

# Database (Railway auto-provisioned)
DATABASE_URL=postgresql://...
REDIS_URL=redis://...

# CometAPI - Gateway LLM unificado (https://api.cometapi.com/console/token)
COMETAPI_KEY=sk-xxxxx
COMETAPI_BASE_URL=https://api.cometapi.com/v1

# Web Search (https://tavily.com)
TAVILY_API_KEY=tvly-xxxxx

# Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# Agent Config
AGENT_SCHEDULE_HOUR=7
AGENT_SCHEDULE_DAYS=mon-fri
AGENT_MAX_NEW_TOOLS=6
AGENT_MAX_UPDATES=5
AGENT_ENABLED=True
